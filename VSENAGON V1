-- === ИНТЕГРАЦИЯ ТРЕТЬЕГО СКРИПТА (TWEEN FARM) В MM2 ===
local isFarming = false
local flySpeed = 18 

local function getAllCoins()
    local coins = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "MainCoin" and v:IsA("BasePart") then
            table.insert(coins, v)
        end
    end
    return coins
end

local farmBtn = Instance.new("TextButton")
farmBtn.Size = UDim2.new(0.95, 0, 0, 32); farmBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
farmBtn.Text = "  Tween Coin Farm: OFF"; farmBtn.TextColor3 = Color3.new(1, 1, 1)
farmBtn.TextXAlignment = Enum.TextXAlignment.Left; farmBtn.Font = Enum.Font.Gotham; farmBtn.Parent = mm2Page
Instance.new("UICorner", farmBtn)

farmBtn.MouseButton1Click:Connect(function()
    isFarming = not isFarming
    farmBtn.Text = "  Tween Coin Farm: " .. (isFarming and "ON" or "OFF")
    farmBtn.TextColor3 = isFarming and Settings.ThemeColor or Color3.new(1, 1, 1)

    if isFarming then
        task.spawn(function()
            while isFarming do
                local character = localPlayer.Character
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                
                if hrp then
                    local coins = getAllCoins()
                    local closestCoin = nil
                    local minDist = math.huge
                    
                    for _, coin in pairs(coins) do
                        if coin.Transparency < 1 then
                            local d = (hrp.Position - coin.Position).Magnitude
                            if d < minDist then
                                minDist = d
                                closestCoin = coin
                            end
                        end
                    end
                    
                    if closestCoin then
                        local dist = (hrp.Position - closestCoin.Position).Magnitude
                        local tInfo = TweenInfo.new(dist / flySpeed, Enum.EasingStyle.Linear)
                        local tween = TweenService:Create(hrp, tInfo, {CFrame = closestCoin.CFrame})
                        
                        tween:Play()
                        tween.Completed:Wait()
                        task.wait(0.1) 
                    else
                        task.wait(1) 
                    end
                end
                task.wait()
            end
        end)
    end
end)

