    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 30); btn.Position = UDim2.new(0.05, 0, 0, 60 + (#sideBar:GetChildren()-2)*35)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35); btn.Text = name; btn.TextColor3 = Color3.new(0.7, 0.7, 0.7)
    btn.Font = Enum.Font.Gotham; btn.Parent = sideBar; Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        for _, p in pairs(pages) do p.page.Visible = false p.btn.TextColor3 = Color3.new(0.7, 0.7, 0.7) end
        page.Visible = true; btn.TextColor3 = Settings.ThemeColor
    end)
    pages[name] = {page = page, btn = btn}; return page
end

local function UpdateTheme()
    local newColor = Color3.fromRGB(Settings.ThemeR, Settings.ThemeG, Settings.ThemeB)
    Settings.ThemeColor = newColor
    Settings.ChamsColor = newColor
    topTitle.TextColor3 = newColor
    logo.TextColor3 = newColor
    for name, p in pairs(pages) do
        if p.page.Visible then p.btn.TextColor3 = newColor end
        for _, child in pairs(p.page:GetChildren()) do
            if child:IsA("TextButton") and child.TextColor3 ~= Color3.new(1,1,1) and child.TextColor3 ~= Color3.new(0.7, 0.7, 0.7) then
                child.TextColor3 = newColor
            elseif child:IsA("Frame") and child:FindFirstChild("SliderBg") then
                local fill = child.SliderBg:FindFirstChild("SliderFill")
                if fill then fill.BackgroundColor3 = newColor end
            end
        end
    end
end

local function addToggle(page, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.95, 0, 0, 32); btn.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    btn.Text = "  " .. text .. ": OFF"; btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextXAlignment = Enum.TextXAlignment.Left; btn.Font = Enum.Font.Gotham; btn.Parent = page
    Instance.new("UICorner", btn)
    local state = false
    
    local function toggle()
        state = not state
        btn.Text = "  " .. text .. (state and ": ON" or ": OFF")
        btn.TextColor3 = state and Settings.ThemeColor or Color3.new(1, 1, 1)
        callback(state)
    end
    
    btn.MouseButton1Click:Connect(toggle)
    
    -- Добавляем скрепку для бинда
    addPinBind(text, toggle, btn)
end

