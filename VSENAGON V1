-- === ФУНКЦИЯ ОПРЕДЕЛЕНИЯ РОЛИ MM2 ===
local function getRole(player)
    if not player or not player.Character then return "Innocent" end
    if player.Backpack:FindFirstChild("Knife") or player.Character:FindFirstChild("Knife") then
        return "Murderer"
    elseif player.Backpack:FindFirstChild("Gun") or player.Character:FindFirstChild("Gun") then
        return "Sheriff"
    end
    return "Innocent"
end

-- === ФУНКЦИИ ОТРИСОВКИ ВИЗУАЛОВ ===
local function applyESP(player)
    if player == localPlayer then return end
    local function setup(char)
        if not char then return end
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local box = char:FindFirstChild("Shark_Box") or Instance.new("SelectionBox")
        box.Name = "Shark_Box"
        box.Adornee = char
        box.Color3 = Settings.ChamsColor
        box.LineThickness = 0.05
        box.Transparency = 0.5
        box.Parent = char

        local bgui = char:FindFirstChild("Shark_Names") or Instance.new("BillboardGui")
        bgui.Name = "Shark_Names"
        bgui.AlwaysOnTop = true
        bgui.Size = UDim2.new(0, 200, 0, 50)
        bgui.ExtentsOffset = Vector3.new(0, 3, 0)
        bgui.Parent = char
        
        local tl = bgui:FindFirstChild("TextLabel") or Instance.new("TextLabel", bgui)
        tl.Name = "TextLabel"
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.TextColor3 = Color3.new(1, 1, 1)
        tl.Font = Enum.Font.GothamBold
        tl.TextSize = 14
        tl.TextStrokeTransparency = 0
        tl.Text = player.Name

        local att1 = hrp:FindFirstChild("Shark_Att_HRP") or Instance.new("Attachment", hrp)
        att1.Name = "Shark_Att_HRP"

        local tracer = workspace.Terrain:FindFirstChild("Tracer_"..player.Name) or Instance.new("Beam", workspace.Terrain)
        tracer.Name = "Tracer_"..player.Name
        local att0 = workspace.Terrain:FindFirstChild("Shark_Att_Screen") or Instance.new("Attachment", workspace.Terrain)
        att0.Name = "Shark_Att_Screen"
        
        tracer.Attachment0 = att0
        tracer.Attachment1 = att1
        tracer.Width0 = 0.005
        tracer.Width1 = 0.005
        tracer.FaceCamera = true
    end
    setup(player.Character)
    player.CharacterAdded:Connect(setup)
end

