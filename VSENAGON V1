local function addPinBind(name, toggleFunc, parentBtn)
    local pin = Instance.new("TextButton")
    pin.Name = "PinBind"
    pin.Size = UDim2.new(0, 26, 0, 26)
    pin.Position = UDim2.new(1, -30, 0, 3)
    pin.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    pin.Text = "📌"
    pin.TextColor3 = Color3.new(1, 1, 1)
    pin.Font = Enum.Font.GothamBold
    pin.TextSize = 14
    pin.Parent = parentBtn
    Instance.new("UICorner", pin)

    pin.MouseButton1Click:Connect(function()
        pin.Text = "..."
        local connection; connection = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.Focus then
                local key = (input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType)
                Settings.CustomBinds[name] = {Key = key, Func = toggleFunc}
                pin.Text = "OK"
                task.delay(1, function() pin.Text = "📌" end)
                connection:Disconnect()
            end
        end)
    end)
end

-- Обработка нажатий для скрепок
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    local key = (input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType)
    for _, data in pairs(Settings.CustomBinds) do
        if data.Key == key then
            data.Func()
        end
    end
end)

