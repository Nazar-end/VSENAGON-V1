-- === ЛОГИКА АИМА С АВТО-ВЫСТРЕЛОМ ===
local function getTarget()
    local target, dist = nil, Settings.FOVSize
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            
            if Settings.SheriffAimOnly then
                if getRole(p) ~= "Murderer" then continue end
            end

            local pos, vis = camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if mag < dist then
                    
                    rayParams.FilterDescendantsInstances = {localPlayer.Character, camera}
                    local res = workspace:Raycast(camera.CFrame.Position, p.Character.HumanoidRootPart.Position - camera.CFrame.Position, rayParams)
                    local isVisible = (res == nil or res.Instance:IsDescendantOf(p.Character))

                    if Settings.WallCheck and not isVisible then continue end
                    
                    dist = mag; target = p
                    
                    -- АВТОВЫСТРЕЛ ПРИ ВИДИМОСТИ (ДЛЯ ШЕРИФА)
                    if Settings.SheriffAimOnly and isVisible and Settings.IsAiming then
                        mouse1click()
                    end
                end
            end
        end
    end
    return target
end

