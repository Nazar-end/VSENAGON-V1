RunService.RenderStepped:Connect(function()
    camera.FieldOfView = Settings.CameraFOV

    local isPressed = false
    local bind = Settings.SheriffAimOnly and Settings.SheriffAimBind or Settings.SilentAimBind
    if bind then
        if tostring(bind):find("MouseButton") then
            isPressed = UserInputService:IsMouseButtonPressed(bind)
        else
            isPressed = UserInputService:IsKeyDown(bind)
        end
    end
    Settings.IsAiming = isPressed
    
    local viewportSize = camera.ViewportSize
    fovCircle.Visible = Settings.ShowFOV
    fovCircle.Size = UDim2.new(0, Settings.FOVSize * 2, 0, Settings.FOVSize * 2)
    fovCircle.Position = UDim2.new(0, viewportSize.X/2 - Settings.FOVSize, 0, viewportSize.Y/2 - Settings.FOVSize)
    fovStroke.Color = Settings.FOVColor

    if Settings.Fullbright then
        Lighting.Ambient = Color3.new(1, 1, 1); Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        Lighting.ClockTime = 14; Lighting.FogEnd = 9e9
    end

    if localPlayer.Character then
        for _, part in pairs(localPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("Decal") then
                if Settings.Invisibility then
                    part.LocalTransparencyModifier = 1
                else
                    part.LocalTransparencyModifier = 0
                end
            end
        end
        local hum = localPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            if hum.Health <= 0 and not Settings.UsedSecondLife then
                local hrp = localPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp then Settings.LastDeathPos = localPlayer.Character:GetPivot() end
            elseif hum.Health > 0 then
                if hum.Health == 100 then Settings.UsedSecondLife = false end
            end
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local char = p.Character
            local box = char:FindFirstChild("Shark_Box")
            local names = char:FindFirstChild("Shark_Names")
            local tracer = workspace.Terrain:FindFirstChild("Tracer_"..p.Name)
            local highlight = char:FindFirstChild("Shark_ESP")
            
            local roleColor = Settings.ThemeColor
            local roleName = p.Name
            if Settings.MM2Roles then
                local role = getRole(p)
                if role == "Murderer" then
                    roleColor = Color3.new(1, 0, 0)
                    roleName = "[MURDERER] " .. p.Name
                elseif role == "Sheriff" then
                    roleColor = Color3.new(0, 1, 0)
                    roleName = "[SHERIFF] " .. p.Name
                end
            end

            if not box and (Settings.BoxEspEnabled or Settings.TracersEnabled or Settings.NameTagsEnabled) then applyESP(p) end
            if Settings.ChamsEnabled then
                if not highlight then highlight = Instance.new("Highlight", char); highlight.Name = "Shark_ESP" end
                highlight.FillColor = roleColor
            elseif highlight then highlight:Destroy() end
            if box then box.Visible = Settings.BoxEspEnabled; box.Color3 = roleColor end
            if names then
                names.Enabled = Settings.NameTagsEnabled; names.TextLabel.TextColor3 = roleColor
                if char:FindFirstChild("Humanoid") then names.TextLabel.Text = roleName .. " [" .. math.floor(char.Humanoid.Health) .. "]" end
            end
            if tracer then
                tracer.Enabled = Settings.TracersEnabled; tracer.Color = ColorSequence.new(roleColor)
                local att0 = workspace.Terrain:FindFirstChild("Shark_Att_Screen")
                if att0 then att0.WorldPosition = camera:ViewportPointToRay(viewportSize.X/2, viewportSize.Y, 0).Origin end
            end
        end
    end

    if Settings.AutoCollect and localPlayer.Character then
        local hrp = localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, v in pairs(cachedCoins) do
                if v and v.Parent then
                    localPlayer.Character:PivotTo(v.CFrame)
                    break 
                end
            end
        end
    end

    if Settings.TriggerBot then
        local targetPart = mouse.Target
        if targetPart and targetPart.Parent:FindFirstChild("Humanoid") then
            local targetPlayer = Players:GetPlayerFromCharacter(targetPart.Parent)
            if targetPlayer and targetPlayer ~= localPlayer then mouse1click() end
        end
    end

    local target = getTarget()
    if target and (Settings.AimbotEnabled or Settings.SilentAim or Settings.SheriffAimOnly) and Settings.IsAiming then
         local targetPos = target.Character.HumanoidRootPart.Position
         if Settings.PredictiveAim then
             local velocity = target.Character.HumanoidRootPart.Velocity
             local distance = (targetPos - camera.CFrame.Position).Magnitude
             local timeToHit = distance / Settings.BulletSpeed
             targetPos = targetPos + (velocity * timeToHit)
         end
         camera.CFrame = CFrame.new(camera.CFrame.Position, targetPos)
    end
    
    if Settings.SpinBot and localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
        localPlayer.Character.HumanoidRootPart.CFrame *= CFrame.Angles(0, math.rad(20), 0)
    end
end)

